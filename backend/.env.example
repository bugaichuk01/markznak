# Async SQLAlchemy URL (asyncpg). В Docker Compose по умолчанию хост БД — db.
DATABASE_URL=postgresql+asyncpg://markznak:markznak@localhost:5432/markznak

# Comma-separated browser origins (CORS)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# EDO Lite transport settings
EDO_LITE_SEND_URL=https://edo-api.crpt.ru/api/v1/document
# Optional bearer token for EDO Lite API
EDO_LITE_AUTH_TOKEN=htzmks30lbm5xu8y
EDO_LITE_TIMEOUT_SECONDS=20
EDO_LITE_RETRY_ATTEMPTS=3
EDO_LITE_RETRY_DELAY_SECONDS=1

# National Catalog sandbox API (create/update card feed)
# Docs: https://docs.crpt.ru/gismt/API_%D0%9D%D0%9A/
NATIONAL_CATALOG_SEND_URL=https://api.nk.sandbox.crptech.ru/v3/feed
NATIONAL_CATALOG_API_KEY=htzmks30lbm5xu8y
# Optional bearer token for National Catalog API
NATIONAL_CATALOG_AUTH_TOKEN=htzmks30lbm5xu8y
NATIONAL_CATALOG_TIMEOUT_SECONDS=20
NATIONAL_CATALOG_RETRY_ATTEMPTS=3
NATIONAL_CATALOG_RETRY_DELAY_SECONDS=1

# Ниже — справочно те же значения, что в docker-compose для сервиса db (можно не задавать в .env бэкенда):
# POSTGRES_USER=markznak
# POSTGRES_PASSWORD=markznak
# POSTGRES_DB=markznak
# СУЗ — OMS API v2: GET и POST {SUZ_API_BASE_URL}/api/v2/{SUZ_PRODUCT_GROUP}/orders?omsId=...
#
# Какой хост ставить: только из вашей инструкции к API СУЗ/OMS (PDF в ЛК ГИС МТ).
# Индекс «Разработчикам»: https://docs.crpt.ru/gismt/%D0%A0%D0%B0%D0%B7%D0%B4%D0%B5%D0%BB_%D0%B4%D0%BB%D1%8F_%D1%80%D0%B0%D0%B7%D1%80%D0%B0%D0%B1%D0%BE%D1%82%D1%87%D0%B8%D0%BA%D0%BE%D0%B2/
# Там же документы «API СУЗ 3.0» и «OMS API 3.0» — базовый URL, версия API и путь могут отличаться от примера в коде.
#
# Важно (проверено запросами с этой машины):
# - https://markirovka.sandbox.crptech.ru — демо-стенд ГИС МТ (в т.ч. True API); по адресу .../api/v2/perfum/orders приходит HTML-страница, а не JSON OMS.
# - Если NATIONAL_CATALOG_SEND_URL=api.nk.sandbox.crptech.ru, а база СУЗ — api.sb.mdlp.crpt.ru, часто смешивают контуры; пробуйте https://suz.sandbox.crptech.ru или сверьтесь по PDF контурности. GET /api/v1/emission-orders/diagnostics/connectivity.
# - https://api.sb.mdlp.crpt.ru — другой контур (mdlp); 404 по /api/v2/… не означает обязательно «неукладка TLS».
# - Для «СУЗ облако» документ задаёт свой URL или локальный шлюз; подтверждайте официальной инструкцией боевого/тестового стенда.
#
# Совпадает с nk sandbox (api.nk.sandbox.crptech.ru выше в этом же .env).
SUZ_API_BASE_URL=https://suz.sandbox.crptech.ru
# Bearer token (security marker/access token) для API v3. Рекомендуемый вариант.
SUZ_AUTH_TOKEN=
# Legacy clientToken (UUID) — fallback, если отдельный Bearer не задан.
SUZ_CLIENT_TOKEN=4c6c0270-be49-4e46-ac0c-34fe187b0d97
# UUID OMS (тот же подставляется в форму «Устройства» через GET .../devices/form-defaults).
SUZ_OMS_ID=ebf3788a-a989-453d-a516-cc86f3b7e856
# Connection ID из ЛК СУЗ (для формы устройства).
SUZ_CONNECTION_ID=343a7575-4303-4974-b3f9-2399e5a8f04e
# Сегмент пути API: perfum, shoes, milk, light, lp, tobacco, photo, tires, pharma
SUZ_PRODUCT_GROUP=perfum
SUZ_TIMEOUT_SECONDS=30
# OpenSSL 3 в контейнере: при [SSL: UNKNOWN_CIPHER_RETURNED] включите true (шифры DEFAULT:@SECLEVEL=1).
SUZ_SSL_COMPAT=true
# TLS: для песочницы без ГОСТ-TLS ставьте false (verify=False + ослабленный SSL до успешной отдачи). Для боевого — true.
SUZ_TLS_VERIFY=false
# После неудачи httpx: curl согласует TLS сам, затем при необходимости — только TLS 1.2 (--tls-max 1.2)
SUZ_CURL_FALLBACK=true

# Поля тела POST «создать заказ на эмиссию» — значения enum из вашей спецификации контура СУЗ.
SUZ_ORDER_CONTACT_PERSON=sandbox@example.com
SUZ_ORDER_RELEASE_METHOD_TYPE=REMARK_PRODUCTION_RU
SUZ_ORDER_CREATE_METHOD_TYPE=SELF_MADE
SUZ_SERIAL_NUMBER_TYPE=OPERATOR
SUZ_MARKING_TEMPLATE_ID=1
SUZ_PRODUCT_CIS_TYPE=UNIT
# Только группа light: contractNumber и contractDate
SUZ_ORDER_CONTRACT_NUMBER=SANDBOX-CONTRACT
SUZ_ORDER_CONTRACT_DATE=2026-01-01